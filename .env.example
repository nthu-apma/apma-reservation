# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/reservation_db"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here-change-this"

# Email (SMTP) - 可使用 Gmail App Password
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
EMAIL_FROM="清華大學研究聯盟預約系統 <noreply@example.com>"

# 初始管理員帳號 (第一次執行 db:seed 時建立)
INITIAL_ADMIN_EMAIL="admin@example.com"
INITIAL_ADMIN_NAME="系統管理員"
INITIAL_ADMIN_PASSWORD="change-this-password"
